# Optional — all values below are already the defaults.
# Copy to .env only if you need to override something.

# SQLite file in the repo root (created automatically on first run)
DATABASE_URL=sqlite+aiosqlite:///./financial.db

# Comma-separated list of valid API keys
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=dev-api-key-change-me

# App environment: development | production
ENV=development
