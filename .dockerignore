# Secrets — never bake into the image
.env
.env.*
!.env.example

# Databases & logs
# financial.db is a local dev artefact; production uses PostgreSQL.
# Never bake a pre-seeded SQLite file into the image.
*.db
*.sqlite3
*.log

# Sample / seed data
# Production data is loaded via POST /api/v1/upload, not baked into the image.
time_series.json

# Dev-only scripts
# seed_data.py calls the running API from outside the container.
scripts/seed_data.py

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/

# Git history
.git/
.gitignore

# OS artefacts
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Test artefacts
.pytest_cache/
htmlcov/
.coverage

# Claude
.claude/
